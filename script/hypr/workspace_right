#!/usr/bin/env sh

# Main monitor: first arg wins, otherwise fall back to the per-host table.
# The configs pass it explicitly; the table keeps already-deployed configs
# (which pass no arg) working until they are re-copied.
MAIN_MONITOR="$1"
if [ -z "$MAIN_MONITOR" ]; then
  case "$HOSTNAME" in
    home) MAIN_MONITOR="DP-2" ;;
    katana) MAIN_MONITOR="LVDS-1" ;;
  esac
fi

# Fail closed. An empty monitor makes the awk range below match every line,
# which inverts the focus guard instead of disabling it.
if [ -z "$MAIN_MONITOR" ]; then
  echo "usage: $(basename "$0") [monitor]" >&2
  exit 1
fi

WORKSPACE_COUNT=5
IS_MAIN_FOCUSED=$(hyprctl monitors | awk "/$MAIN_MONITOR/,EOF" | sed -e '/focused: yes/!d')
FOCUSED_WORKSPACE_ID=$(hyprctl monitors | awk "/$MAIN_MONITOR/,EOF" | sed -e '/active workspace/!d' | cut -c 20)

if [ -n "$IS_MAIN_FOCUSED" ]
then
  echo "Main is focused"
else
  exit 1
fi

TARGET_WORKSPACE=$(( FOCUSED_WORKSPACE_ID + 1 ))

if [ "$TARGET_WORKSPACE" -gt "$WORKSPACE_COUNT" ]; then
  TARGET_WORKSPACE=1
fi

hyprctl dispatch focusworkspaceoncurrentmonitor $TARGET_WORKSPACE
